{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/check-prereqs.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/check-sensitive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/validate-rule.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude finished\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Write(.env*)",
      "Edit(.env*)",
      "Read(*.key)",
      "Write(*.key)",
      "Edit(*.key)",
      "Read(*.pem)",
      "Write(*.pem)",
      "Edit(*.pem)",
      "Read(secrets/*)",
      "Write(secrets/*)",
      "Edit(secrets/*)"
    ]
  },
  "costThreshold": {
    "warningAt": 5.00,
    "hardLimit": 20.00
  }
}
